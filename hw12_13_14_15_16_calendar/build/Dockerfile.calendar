FROM golang:1.23 as build

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG LDFLAGS
RUN CGO_ENABLED=0 go build -ldflags "$LDFLAGS" -o calendar ./cmd/calendar

FROM alpine:3.9

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=build /build/calendar /app/calendar
COPY configs/config.yaml /etc/calendar/config.yaml

CMD ["/app/calendar", "-config", "/etc/calendar/config.yaml"]
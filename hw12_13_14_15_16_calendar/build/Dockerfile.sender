FROM golang:1.23 as build

WORKDIR /build

COPY go.mod go.sum ./
RUN go mod download

COPY . .

ARG LDFLAGS
RUN CGO_ENABLED=0 go build -ldflags "$LDFLAGS" -o sender ./cmd/sender

FROM alpine:3.9

RUN apk add --no-cache ca-certificates bash gettext

WORKDIR /app

COPY --from=build /build/sender /app/sender
COPY deployments/config.sender.yaml /etc/calendar/config.yaml
COPY deployments/docker-entrypoint.sh /docker-entrypoint.sh
RUN chmod +x /docker-entrypoint.sh

ENTRYPOINT ["/docker-entrypoint.sh"]
CMD ["/app/sender", "-config", "/etc/calendar/config.yaml"]